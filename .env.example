# Copy this file to .env and fill in the values
# cp .env.example .env

# ==============================
# MySQL
# ==============================
MYSQL_DATABASE=highteenday_db
MYSQL_ROOT_PASSWORD=

# ==============================
# JWT
# ==============================
JWT_KEY=

# ==============================
# AWS S3
# Credentials via ~/.aws/credentials (run: aws configure)
# ==============================
S3_BUCKET=

# ==============================
# OAuth2
# ==============================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==============================
# School API (NEIS)
# ==============================
NEIS_API_KEY=
